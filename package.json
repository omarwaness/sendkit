{
    "name": "sendkit-workspace",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "format": "oxfmt . --write",
        "format:check": "oxfmt . --check",
        "lint": "oxlint . --deny-warnings",
        "lint:fix": "oxlint . --fix",
        "build:core": "bun run --filter sendkit-core build",
        "build:cli": "bun run --filter sendkit build",
        "build:local-mcp": "bun run --filter sendkit-mcp build",
        "dev:cli": "bun run packages/cli/src/index.ts",
        "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
        "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
        "release:pack:core": "bun run --filter sendkit-core pack:dry",
        "release:pack:cli": "bun run --filter sendkit pack:dry",
        "release:pack:local-mcp": "bun run --filter sendkit-mcp pack:dry",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "oxfmt": "^0.58.0",
        "oxlint": "^1.73.0",
        "tsdown": "^0.22.4",
        "typescript": "^7.0.2",
        "unrun": "^0.3.1"
    }
}